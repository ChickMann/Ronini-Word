<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <ui:VisualElement name="RowContainer" style="flex-direction: row; height: 35px; align-items: center; border-bottom-width: 1px; border-bottom-color: rgba(255, 255, 255, 0.1); padding-left: 5px; padding-right: 5px; justify-content: space-between; flex-shrink: 0;">
        <ui:VisualElement style="flex-direction: row; align-items: center; flex-grow: 1; overflow: hidden;">
            <ui:Label text="1." name="lblRank" style="width: 25px; -unity-font-style: bold; color: rgb(255, 193, 7); font-size: 14px;"/>
            <ui:Label text="PlayerName" name="lblName" style="font-size: 14px; color: rgb(240, 240, 240); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"/>
        </ui:VisualElement>
        <ui:Label text="9999" name="lblScore" style="min-width: 60px; -unity-text-align: middle-right; font-size: 14px; color: rgb(0, 255, 255); -unity-font-style: bold;"/>
    </ui:VisualElement>
</ui:UXML>
